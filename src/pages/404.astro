---
import Layout from '../layouts/Layout.astro';

const title = 'Page Not Found';
const path = new URL(Astro.request.url).pathname;
---

<Layout title={title}>
    <h1 class="text-xl text-center font-bold pt-8 pb-4">{title}</h1>
    <p class="text-center pb-8">Path: <span class="underline">{path}</span></p>
    <img class="mx-auto pb-8" src="/favicon.svg" alt="Logo" width="32px" />
</Layout>